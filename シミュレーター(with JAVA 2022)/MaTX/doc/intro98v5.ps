/bf-v exch def
/bf-h exch def
/savecurfont currentfont def
findfont dup setfont
3 -1 roll
/bf-stand exch def
[
bf-stand stringwidth pop
dup bf-h exch div
exch bf-v exch div 0 0 3 -1 roll
0 0
] makefont def
savecurfont setfont
