TeXDict begin
    /ObliqueSlant {
	[1 0 4 -1 roll dup sin exch cos div 1 0 0]
	exch findfont exch makefont definefont pop
    } bind def

    /SlantFont {
	[1 0 4 -1 roll 1 0 0]
	exch findfont exch makefont definefont pop
    } def 

    /ExtendFont {
	[exch 0 0 1 0 0]
	exch findfont exch makefont definefont pop
    } def
end % TeXDict
