pop load
}{
pop {
1 sub 4 1 roll
3 { 3 index add neg dup 0 lt {pop 0} if 3 1 roll } repeat
setrgbcolor pop
} bind
} ifelse def
/normalscale {
Resolution 72 div Resolution 72 div neg scale
magscale { DVImag dup scale } if
0 setgray
} def
