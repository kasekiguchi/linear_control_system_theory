hof vof translate
BBOX {
rotat rotate
hsi 0 eq {
vsi 0 eq {
hsc vsc
}{
vsi ury lly sub div dup
}ifelse
}{
vsi 0 eq {
hsi urx llx sub div dup
}{
hsi urx llx sub div vsi ury lly sub div
} ifelse
} ifelse
scale
llx neg ECL{ury}{lly}ifelse neg translate
CLIP {
newpath
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath clip
} if
newpath
}{
@setclipper hsc vsc scale rotat rotate
} ifelse
/CTM matrix currentmatrix def
end
