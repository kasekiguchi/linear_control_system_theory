*** Size Fucntions:           Rows, Cols, degree, length, size,

*** Matrix Generation:        I, Z, ONE, linspace, logspace, rand, randn
    Functions:                diag, diag2vec, vec2diag,
                              reshape, fliplr, flipud,

*** Real-Imaginary-part:      Re, Im, Nu, De
    Numerator, Denominator:

***                           acos, acosh, asin, asinh, atan, atanh, atan2,
                              cos, cosh, sin, sinh, tan, tanh,

*** Exponetial, Logarithm     exp, log, log10, sqrt,

*** Bit operation             bit_and, bit_or, bit_comp, bit_xor,
                              bit_lshift, bit_rshift

*** Matrix Size Functions:    max, max_col, max_row, maximum,
                              min, min_col, min_row, minimum,
                              mean, mean_col, mean_row,
                              sum, sum_col, sum_row,
                              prod, prod_col, prod_row,
                              std, std_col, std_row,
                              cumsum, cumsum_col, cumsum_row
                              cumprod, cumprod_col, cumprod_row
                              det, trace, rank, flobnorm, infnorm, norm,

*** Complex Functions:        abs, arg, conj, isreal, iscomplex

*** Polynomial,               derivative, higher, lower, integral,
    Rational Functions:       poles, roots, zeros, 

*** Eigen Functions:          eig, eigen, eigval, eigvec,

*** Singular Value Functions: svd, sing, singleftvec, singrightvec, 
                              singval, maxsing, minsing, 

*** Decomposition Functions:  hess, lu, qr, qr_nop, qz, schur, svd

*** String Functions:         printf, sprintf
                              scanf, sscanf, strchr

*** File Functions:           fopen, feof, fprintf, fscanf, fread, fwrite

*** Simulation Functions:     rkf45, rngkut4, 
                              Ode, OdeAuto, Ode45, Ode45Auto,
                              OdeHybrid, OdeHybridAuto,
                              Ode45Hybrid, Ode45HybridAuto,
                              OdeStop(), OdeXY()

*** Miscellaneous Functions:  ceil, floor, fix, round, round2z
                              kernel, pseudoinv, vectorprod, rem, fact, sgn
                              all, all_col, all_col, any, any_col, any_row,
                              eval, find, sort, makelist, appendlist,
                              system, error, warning, isnan, isinf, isfinite

/* Cols */
          Integer Cols(Matrix M1):    Column number of a matrix
/* Cols */

/* De */
          Polynomial De(Rational R1): denominator of a rational function
          Array      De(Array A1):    denominator of a rational function array
/* De */

/* I */
          Matrix I(Integer i1):             identity matrix
          Matrix I(Integer i1, Integer i2): identity matrix
          Matrix I(Matrix M1):              identity matrix
          Array  I(Array A1):               identity matrix
/* I */

/* Im */
          Real       Im(Complex c1):      imaginary part of a complex number
          Array      Im(CoArray A1):      imaginary part of an array
          Matrix     Im(CoMatrix M1):     imaginary part of a matrix
          Polynomial Im(CoPolynomial P1): imaginary part of a polynomial
          Rational   Im(CoRational R1):   imaginary part of a rational function
/* Im */

/* Nu */
          Polynomial Nu(Rational R1): numerator of a rational function
          Array      Nu(Array A1):    numerator of a rational function array
/* Nu */

/* Ode */
          {T, X, U} = Ode(t0, t1, x0, diff_eqs, ..., link_eqs, h, dtsav);
          Array  T, X, U;
          Real   t0, t1, h(= 4.0E-2), dtsav(= 1.0E-3);
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to 4th order
          Runge-Kutta methods with the prespecified step 'h' between [t0 t1].
/* Ode */

/* OdeAuto */
          {T, X, U} = OdeAuto(t0, t1, x0, diff_eqs, ..., 
                                  link_eqs, eps, dtsav, dtmin, dtmax);
          Array  T, X, U;
          Real   t0, t1, eps(= 1.0E-6), dtsav(= 1.0E-3);
          Real   dtmin(= EPS), dtmax(= abs(t1-t0)/5), dtmax = max(dtmax,dtsav);
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to 4th order
          Runge-Kutta methods automatically changing the step to guarantee
          the prespecified error between [t0 t1]
/* OdeAuto */

/* Ode45 */
          {T, X, U} = Ode45(t0, t1, x0, diff_eqs, ..., link_eqs, h, dtsav);
          Array  T, X, U;
          Real   t0, t1, h(= 4.0E-2), dtsav(= 1.0E-3);
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to
          RKF45 methods with the prespecified step 'h' between [t0 t1].
/* Ode45 */

/* Ode45Auto */
          {T, X, U} =
             Ode45Auto(t0, t1, x0, diff_eqs, ..., 
                                   link_eqs, eps, dtsav, dtmin, dtmax);
          Array  T, X, U;
          Real   t0, t1, eps(= 1.0E-6), dtsav(= 1.0E-3);
          Real   dtmin(= EPS), dtmax(= abs(t1-t0)/5), dtmax = max(dtmax,dtsav);
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to RKF45 methods
          automatically changing the step to guarantee the prespecified error
          between [t0 t1]
/* Ode45Auto */

/* OdeHybrid */
          {T, X, U} = OdeHybrid(t0, t1, dt, x0, diff_eqs, ..., 
                                                link_eqs, h, dtsav);
          Array  T, X, U;
          Real   t0, t1, dt, h(= 4.0E-2), dtsav(= max(h, 1.0E-3));
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to 4th order
          Runge-Kutta methods with the prespecified step 'h' between [t0 t1],
          where the external input is constant for the prespecified sampling
          interval.
/* OdeHybrid */

/* OdeHybridAuto */
         {T, X, U} = OdeHybridAuto(t0, t1, dt, x0, diff_eqs, ...,
                                        link_eqs, eps, dtsav, dtmin, dtmax);
          Array  T, X, U;
          Real   t0, t1, dt, eps(= 1.0E-6), dtsav(= 1.0E-3);
          Real   dtmin(= EPS), dtmax(= abs(t1-t0)/5), dtmax = max(dtmax,dtsav);
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to 4th order
          Runge-Kutta methods automatically changing the step to guarantee the
          prespecified error between [t0 t1], where the external input is
          constant for the prespecified sampling interval.
/* OdeHybridAuto */

/* Ode45Hybrid */
          {T, X, U} = Ode45Hybrid(t0, t1, dt, x0, diff_eqs, ..., 
                                                       link_eqs, h, dtsav);
          Array  T, X, U;
          Real   t0, t1, dt, h(= 4.0E-2), dtsav(= max(h, 1.0E-3));
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to RKF45 methods
          with the prespecified step 'h' between [t0 t1], where the external
          input is constant for the prespecified sampling interval.
/* Ode45Hybrid */

/* Ode45HybridAuto */
          {T, X, U} = Ode45HybridAuto(t0, t1, dt, x0, diff_eqs, ...,
                                         link_eqs, eps, dtsav, dtmin, dtmax);
          Array  T, X, U;
          Real   t0, t1, dt, eps(= 1.0E-6), dtsav(= 1.0E-3);
          Real   dtmin(= EPS), dtmax(= abs(t1-t0)/5), dtmax = max(dtmax,dtsav);
          Matrix x0;
          Matrix diff_eqs(), link_eqs();

          To solve ordinary differential equations according to RKF45 methods
          automatically changing the step to guarantee the prespecified error
          between [t0 t1], where the external input is constant for the
          prespecified sampling interval.
/* Ode45HybridAuto */

/* OdeStop */
          OdeStop();

          The function stops the execution of Ode(), OdeAuto(),
          OdeHybrid(), ..., and returns the result.
/* OdeStop */

/* OdeXY */
          {X_t, Y_t} = OdeXY(t)
          Array X_t, Y_t;
          Real t;

          The function retuns the state X_t and input-output Y_t
          at time t.  Those vectors are approximated linearly.
/* OdeXY */

