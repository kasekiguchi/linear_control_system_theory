/* eig */
          List eig(Matrix M1):            eigenvalue and eigenvector
                                          {val, vec} = eig(A);
                                          Matrix val: eigenvalues
                                          Matrix vec: eigenvectors
                                          A * vec = vec * val

          List eig(Matrix M1, Matrix M2): generalized eigenvalue, eigenvector
                                          {val, vec} = eig(A, B);
                                          Matrix val: generalized eigenvalues
                                          Matrix vec: generalized eigenvectors
                                          A * vec = B * vec * val


          List eig(Matrix M1, "S"):       eigenvalue and eigenvector
                                          of symmetric matrices

                                          The 2nd argument must be a constant
                                          string whose first character is
                                          's' or 'S'. (Ex. "Symmetric")

                                          {val, vec} = eig(A, "S");
                                          Matrix val: eigenvalues
                                          Matrix vec: eigenvectors
                                          A * vec = vec * val

          List eig(Matrix M1, "H"):       eigenvalue and eigenvector
                                          of hermitian matrices
                                          {val, vec} = eig(A, "H");
                                          Matrix val: eigenvalues
                                          Matrix vec: eigenvectors
                                          A * vec = vec * val

                                          The 2nd argument must be a constant
                                          string whose first character is
                                          'h' or 'H'. (Ex. "Hermit")

/* eig */

/* eigval */
      Matrix eigval(Matrix M1):            eigenvalue
      Matrix eigval(Matrix M1, Matrix M2): generalized eigenvalue

      Matrix eigval(Matrix M1, "S"):       eigenvalue of symmetric matrices

                                           The 2nd argument must be a constant
                                           string whose first character is
                                           's' or 'S'. (Ex. "Symmetric")

      Matrix eigval(Matrix M1, "H"):       eigenvalue of hermitian matrices

                                           The 2nd argument must be a constant
                                           string whose first character is
                                           'h' or 'H'. (Ex. "Hermitian")
/* eigval */

/* eigvec */
      Matrix eigvec(Matrix M1):            eigenvector
      Matrix eigvec(Matrix M1, Matrix M2): generalized eigenvector

      Matrix eigvec(Matrix M1, "S"):       eigenvector of symmetric
                                           matrices

                                           The 2nd argument must be a constant
                                           string whose first character is
                                           's' or 'S'. (Ex. "Symmetric")

      Matrix eigvec(Matrix M1, "H"):       eigenvector of hermitian
                                           matrices

                                           The 2nd argument must be a constant
                                           string whose first character is
                                           'h' or 'H'. (Ex. "Hermitian")
/* eigvec */

