\newcounter{chap}
\newcounter{sec}
\newcommand{\chapsec}{\arabic{chap}.\arabic{sec}}
\renewcommand{\theequation}{\arabic{chap}.\arabic{equation}}
%
% 図や表の名前を変える
%
\renewcommand{\thefigure}{\arabic{chap}.\arabic{figure}}
\renewcommand{\thetable}{\arabic{chap}.\arabic{table}}
\renewcommand{\figurename}{\bfseries Fig. \arabic{chap}.\arabic{figure}}
% ここは結構ゴリおし．番号がどうしても出なかった．
\renewcommand{\tablename}{\bfseries Table}

%
% 章扉のページ
%
\newcommand{\chap}[1]{
	\setcounter{equation}{0}
	\setcounter{figure}{0}
	\setcounter{table}{0}
	\stepcounter{chap}
	\vspace{2cm}

	\frame{
		\begin{center}%\mbox{}\bfseries\large\green
		{\large \textcolor{blue}{第\arabic{chap}章 #1}}
		\end{center}
	}
}
